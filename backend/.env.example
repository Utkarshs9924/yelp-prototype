# Copy to backend/.env and fill in real values. Never commit .env.

# --- Database (local MySQL OR Azure MySQL) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=yelp_db

# JWT signing secret (required for login/signup — use a long random string in production)
JWT_SECRET=your_secret_key_here

# --- Azure MySQL (team shared DB — use these instead of localhost when provided) ---
# DB_HOST=yelp-db.mysql.database.azure.com
# DB_USER=yelpadmin
# DB_PASSWORD="<AZURE_MYSQL_PASSWORD>"
# DB_NAME=yelp_db

# --- Azure OpenAI (required for /chat — LangChain agent + embeddings) ---
# Deployments in code must match your resource: text-embedding-3-small, gpt-4o-mini
# AZURE_OPENAI_API_KEY="<AZURE_OPENAI_KEY>"
# AZURE_OPENAI_ENDPOINT="https://<your-resource>.openai.azure.com/"

# --- Tavily (real-time web search tool for the AI Assistant / ChatBot — Lab 1) ---
# Get a key at https://tavily.com — enables tavily_search in chat agent when set
# TAVILY_API_KEY="tvly-..."

# --- Azure Blob (restaurant photo upload/delete — optional) ---
# AZURE_STORAGE_CONNECTION_STRING="<connection_string>"
# AZURE_STORAGE_CONTAINER_NAME=restaurant-photos
