# Copy to .env.production and fill in real values. Never commit .env.production.
# docker-compose reads this automatically when run with: docker compose --env-file .env.production up

MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=yelp
DB_NAME=yelp_db
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
JWT_SECRET=change_me_to_a_random_string
